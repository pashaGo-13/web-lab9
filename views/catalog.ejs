<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Зоопарк</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>Управление зоопарком</h1>

    <div class="controls" style="margin-bottom: 20px; display: flex; gap: 10px; align-items: center;">
        <button onclick="window.location.href='/'">Главная</button>
        
        <input type="text" id="searchInput" placeholder="Поиск по названию..." value="<%= currentSearch %>">
        
        <select id="sortSelect">
            <option value="none" <%= currentSort === 'none' ? 'selected' : '' %>>Без сортировки</option>
            <option value="asc" <%= currentSort === 'asc' ? 'selected' : '' %>>по возрастанию</option>
            <option value="desc" <%= currentSort === 'desc' ? 'selected' : '' %>>по убыванию</option>
        </select>

        <button onclick="applyFilters(1)">Применить</button>
        <button onclick="window.location.href='/catalog'">Сбросить</button>
    </div>

    <table>
        <thead>
            <tr>
                <th>Имя</th>
                <th>Уход</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            <% if (animals.length > 0) { %>
                <% animals.forEach(animal => { %>
                    <tr>
                        <td><b><%= animal.name %></b></td>
                        <td><%= animal.care %></td>
                        <td>
                            <button onclick="editAnimal(<%= animal.id %>, '<%= animal.name %>', '<%= animal.care %>')">✒️</button>
                            <button onclick="deleteAnimal(<%= animal.id %>)">❌</button>
                        </td>
                    </tr>
                <% }); %>
            <% } else { %>
                <tr><td colspan="3">Ничего не найдено</td></tr>
            <% } %>
        </tbody>
    </table>

    <div class="pagination" style="margin-top: 20px;">
        <% for(let i = 1; i <= totalPages; i++) { %>
            <button onclick="applyFilters(<%= i %>)" <%= i === currentPage ? 'disabled' : '' %>>
                <%= i %>
            </button>
        <% } %>
    </div>

    <div style="margin-top: 20px;">
        <button onclick="addAnimal()">➕ Добавить</button>
    </div>

    <script>
        function applyFilters(page) {
            const search = document.getElementById('searchInput').value;
            const sort = document.getElementById('sortSelect').value;
            const url = new URL(window.location.href);
            
            url.searchParams.set('page', page);
            url.searchParams.set('search', search);
            url.searchParams.set('sort', sort);
            
            window.location.href = url.toString();
        }

        async function addAnimal() {
            const name = prompt("Имя:");
            const care = prompt("Уход:");
            if (name && care) {
                await fetch('/items', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, care })
                });
                window.location.reload();
            }
        }

        async function deleteAnimal(id) {
            if (confirm('Удалить?')) {
                await fetch(`/items/${id}`, { method: 'DELETE' });
                window.location.reload();
            }
        }

        async function editAnimal(id, oldName, oldCare) {
            const name = prompt("Новое имя:", oldName);
            const care = prompt("Новый уход:", oldCare);
            if (name && care) {
                await fetch(`/items/${id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name, care })
                });
                window.location.reload();
            }
        }
    </script>
</body>
</html>